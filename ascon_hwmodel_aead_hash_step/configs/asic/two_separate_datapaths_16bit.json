{
  "algorithm": {
    "features": [
      "aead128"
    ],
    "include_cxof": false,
    "include_decrypt": true,
    "include_encrypt": true,
    "include_hash": false,
    "include_xof": false
  },
  "context": {
    "context_count": 2,
    "context_id_bits": 1,
    "interleave_depth": 1,
    "scheduling": "single_context",
    "storage": "single_context_regs"
  },
  "datapath": {
    "absorb_width": "16",
    "io_word_width": "16",
    "key_width_bits": 128,
    "lane_width": "16",
    "profile": "16_bit",
    "rate_width_bits": 128,
    "serialized_absorb": true,
    "serialized_state_update": true,
    "share_key_registers": false,
    "share_pad_logic": true,
    "split_encrypt_decrypt_control": true,
    "state_width_bits": 320,
    "tag_width_bits": 128
  },
  "description": "ASIC architecture with independent AEAD encryption and decryption datapaths. This costs more area than a shared datapath but allows one encrypt and one decrypt operation to progress concurrently.",
  "io": {
    "data_bus_bits": 16,
    "flow_control": "valid_ready",
    "interface_style": "stream",
    "separate_ad_text_channels": false,
    "separate_encrypt_decrypt_ports": true,
    "supports_backpressure": true
  },
  "name": "asic_two_datapaths_16_bit_column_serial",
  "padding": {
    "length_handling": "internal_byte_counter",
    "strategy": "fsm_assisted",
    "supports_bit_granular_lengths": false,
    "supports_partial_blocks": true
  },
  "permutation": {
    "context_interleaving_required": false,
    "pipeline_initiation_interval": null,
    "pipeline_stages": 0,
    "register_between_rounds": false,
    "rounds_per_cycle": 1,
    "sbox_columns_per_cycle": 1,
    "sbox_style": "boolean",
    "share_round_logic": true,
    "style": "column_serial",
    "unroll_factor": 1
  },
  "rtl": {
    "emit_separate_files": true,
    "include_reference_comments": true,
    "language": "systemverilog",
    "reset_style": "async_active_low"
  },
  "security": {
    "clear_state_on_done": true,
    "constant_time_control": true,
    "duplicate_control_fsm_checks": false,
    "randomness_bits_per_cycle": 0,
    "side_channel_protection": "none"
  },
  "target": "asic",
  "topology": {
    "decrypt_datapaths_per_engine": 1,
    "encrypt_datapaths_per_engine": 1,
    "engine_capability": "aead_encrypt_decrypt",
    "engine_count": 1,
    "expected_parallel_operations": 2,
    "family": "separate_enc_dec_datapaths",
    "mode_fsm_count_per_engine": 2,
    "shared_encrypt_decrypt_datapath": false,
    "shared_permutation_per_engine": false,
    "total_decrypt_datapaths": 1,
    "total_encrypt_datapaths": 1
  }
}
