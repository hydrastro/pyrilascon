{
  "schema_version": 1,
  "name": "tangnano9k_neorv32_stream_axis_mmio",
  "description": "Board-facing manifest for the NEORV32 CFS wrapper that drives the stream-native ASCON AEAD128 backend through the CPU-driven AXI-stream MMIO bridge.",
  "board": {
    "vendor": "Sipeed",
    "name": "Tang Nano 9K",
    "fpga_family": "Gowin GW1NR-9C",
    "status": "bringup_scaffold"
  },
  "top": {
    "neorv32_cfs_entity": "neorv32_cfs",
    "cfs_wrapper": "rtl/neorv32/neorv32_cfs_ascon_stream_axis_mmio.vhd",
    "accelerator_system": "rtl/common/ascon_accel_stream_aead128_axis_mmio_system.v"
  },
  "memory_map": {
    "ascon_cfs_base": "0xFFEB0000",
    "csr_window": {
      "base": "0xFFEB0000",
      "offset": "0x000",
      "size_bytes": 256,
      "description": "Frozen ASCON control/status/key/nonce/tag ABI"
    },
    "axis_mmio_window": {
      "base": "0xFFEB0100",
      "offset": "0x100",
      "size_bytes": 256,
      "description": "CPU-driven 128-bit AXI-stream bridge window"
    }
  },
  "rtl": {
    "primary_file_list": "rtl/neorv32/ascon_cfs_stream_axis_mmio_file_list.f",
    "language_mix": ["verilog", "vhdl"],
    "required_sources": [
      "rtl/common/ascon_accel_regs.vh",
      "rtl/common/ascon_round_comb.v",
      "rtl/common/ascon_accel_mmio_regs.v",
      "rtl/stream/ascon_aead128_stream_encrypt.v",
      "rtl/stream/ascon_aead128_stream_decrypt_buffered.v",
      "rtl/stream/ascon_aead128_stream.v",
      "rtl/common/ascon_accel_stream_aead128_top.v",
      "rtl/common/ascon_axis_mmio_bridge.v",
      "rtl/common/ascon_accel_stream_aead128_axis_mmio_system.v",
      "rtl/neorv32/neorv32_cfs_ascon_stream_axis_mmio.vhd"
    ]
  },
  "firmware": {
    "directory": "firmware/neorv32_ascon_benchmark",
    "make_mode": "USE_CFS_AXIS_MMIO=1",
    "command": "make USE_CFS_AXIS_MMIO=1 neorv32-stream-build-firmware",
    "defines": {
      "ASCON_BENCH_USE_AXIS_MMIO": "1",
      "ASCON_ACCEL_BASE_ADDR": "0xFFEB0000u",
      "ASCON_ACCEL_AXIS_MMIO_BASE_ADDR": "0xFFEB0100u"
    }
  },
  "validation": {
    "pre_board": [
      "python -m pytest -q tests/test_neorv32_stream_cfs_integration.py",
      "python -m pytest -q tests/test_stream_axis_mmio_system_sim.py",
      "make stream-axis-mmio-system-sim"
    ],
    "board_bringup_order": [
      "build firmware with USE_CFS_AXIS_MMIO=1",
      "integrate rtl/neorv32/neorv32_cfs_ascon_stream_axis_mmio.vhd as the NEORV32 CFS implementation",
      "synthesize the NEORV32 SoC for Tang Nano 9K",
      "program SRAM",
      "capture UART benchmark output",
      "compare software cycles, hardware cycles, and speedup"
    ]
  }
}
