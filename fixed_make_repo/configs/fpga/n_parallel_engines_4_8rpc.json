{
  "algorithm": {
    "features": [
      "aead128",
      "hash256",
      "xof128",
      "cxof128"
    ],
    "include_cxof": true,
    "include_decrypt": true,
    "include_encrypt": true,
    "include_hash": true,
    "include_xof": true
  },
  "context": {
    "context_count": 48,
    "context_id_bits": 6,
    "contexts_per_engine": 12,
    "interleave_depth": 12,
    "profile": "fpga_bram_lutram",
    "rollback_supported": false,
    "scheduling": "dynamic_queue",
    "shadow_state": false,
    "state_memory_read_ports": 1,
    "state_memory_write_ports": 1,
    "storage": "fpga_lutram_context_memory"
  },
  "control": {
    "axi_stream_command_channels": 3,
    "command_fifo_depth": 32,
    "csr_register_count": 0,
    "microcode_words": 256,
    "profile": "axi_stream_microcoded_hybrid",
    "scheduler_required": true,
    "supports_concurrent_modes": true,
    "supports_descriptors": true,
    "supports_dma": false,
    "supports_runtime_algorithm_select": true
  },
  "datapath": {
    "absorb_width": "128",
    "io_word_width": "128",
    "key_width_bits": 128,
    "lane_width": "128",
    "profile": "128_bit",
    "rate_width_bits": 128,
    "serialized_absorb": false,
    "serialized_state_update": false,
    "share_key_registers": false,
    "share_pad_logic": false,
    "split_encrypt_decrypt_control": true,
    "state_width_bits": 320,
    "tag_width_bits": 128
  },
  "description": "FPGA architecture with N independent ASCON engines. Area scales roughly with N; throughput should scale close to linearly for independent messages if memory/I/O can feed all engines.",
  "io": {
    "data_bus_bits": 512,
    "flow_control": "valid_ready",
    "interface_style": "descriptor_stream",
    "separate_ad_text_channels": false,
    "separate_encrypt_decrypt_ports": false,
    "supports_backpressure": true
  },
  "name": "fpga_4_parallel_engines_eight_rounds_per_cycle",
  "padding": {
    "final_bytemask": true,
    "final_bytemask_width": 64,
    "length_handling": "streaming_final_bytemask",
    "pad_in_core": true,
    "partial_block_buffer_bytes": 64,
    "profile": "streaming_final_bytemask",
    "requires_total_length": false,
    "strategy": "inline_combinational",
    "supports_arbitrary_byte_lengths": true,
    "supports_bit_granular_lengths": false,
    "supports_partial_blocks": true,
    "tracks_byte_count": false
  },
  "permutation": {
    "context_interleaving_required": false,
    "pipeline_initiation_interval": null,
    "pipeline_stages": 0,
    "register_between_rounds": false,
    "rounds_per_cycle": 8,
    "sbox_columns_per_cycle": 64,
    "sbox_style": "lut5",
    "share_round_logic": false,
    "style": "round_unrolled",
    "unroll_factor": 8
  },
  "rtl": {
    "emit_separate_files": true,
    "include_reference_comments": true,
    "language": "systemverilog",
    "reset_style": "async_active_low"
  },
  "security": {
    "clear_state_on_done": true,
    "constant_time_control": true,
    "constant_time_decrypt_failure": true,
    "constant_time_tag_compare": true,
    "decryption_release_policy": "buffer_until_tag_verify",
    "duplicate_compute_check": true,
    "duplicate_control_fsm_checks": true,
    "fault_detection": "duplicate_compute",
    "plaintext_buffer_capacity_bytes": 65536,
    "plaintext_buffer_storage": "bram_fifo",
    "plaintext_buffer_until_tag_verified": true,
    "profile": "fpga_fault_detect_rand_counter_consttime_tag",
    "randomized_counter_hardening": true,
    "randomness_bits_per_cycle": 0,
    "side_channel_protection": "none",
    "zeroize_plaintext_buffer_on_failure": true
  },
  "target": "fpga",
  "topology": {
    "aead_core_count": 4,
    "contexts_per_pipeline": 1,
    "decrypt_datapaths_per_engine": 1,
    "encrypt_datapaths_per_engine": 1,
    "engine_capability": "aead_hash_xof",
    "engine_count": 4,
    "expected_parallel_operations": 4,
    "family": "parallel_engines",
    "mode_fsm_count_per_engine": 1,
    "permutation_pipeline_count": 0,
    "shared_encrypt_decrypt_datapath": false,
    "shared_permutation_per_engine": false,
    "shared_pipeline_across_contexts": false,
    "top_level_profile": "n_identical_aead_cores",
    "total_aead_cores": 4,
    "total_decrypt_datapaths": 4,
    "total_encrypt_datapaths": 4,
    "total_permutation_pipelines": 0
  }
}
